  "poets": [
    {
      "id": "saadi",
      "name": "سعدی (Saadi Shirazi)",
      "bio": "Abū-Muhammad Muslih al-Dīn bin Abdallāh Shīrāzī, known as Saadi, was one of the major Persian poets of the medieval period. He is recognized for the quality of his writings and the depth of his social and moral thoughts.",
      "themes": "Ethics, Humanism, Love, Social Justice",
      "avatar": "🏛",
      "famous_poem": "بنی آدم اعضای یکدیگرند"
    },
    {
      "id": "rumi",
      "name": "مولوی (Rumi)",
      "bio": "Jalāl al-Dīn Muḥammad Rūmī, known as Rumi, was a 13th-century Persian poet, Sufi mystic, and scholar whose spiritual legacy transcends national borders.",
      "themes": "Mysticism, Divine Love, Unity, Acceptance",
      "avatar": "🕊",
      "famous_poem": "عشق جان است و جهان در کار او"
    },
    {
      "id": "hafez",
      "name": "حافظ (Hafez)",
      "bio": "Khwāja Shams-ud-Dīn Muḥammad Ḥāfeẓ-e Shīrāzī, known as Hafez, was a Persian lyric poet whose collected works are regarded as a pinnacle of Persian literature.",
      "themes": "Spiritual Love, Wine, Hypocrisy, Fate",
      "avatar": "🍷",
      "famous_poem": "سحر با باد می‌گفتم حدیث آرزومندی"
    },
    {
      "id": "khayyam",
      "name": "خیام (Omar Khayyam)",
      "bio": "Omar Khayyam was a Persian polymath, mathematician, astronomer, historian, and philosopher, widely known for his Rubaiyat quatrains.",
      "themes": "Existentialism, Transience of Life, Carpe Diem",
      "avatar": "⏳",
      "famous_poem": "این یک دو روز زندگی به شادی بگذران"
    },
    {
      "id": "ferdowsi",
      "name": "فردوسی (Ferdowsi)",
      "bio": "Hakīm Abu'l-Qāsim Ferdowsi Tusi, known as Ferdowsi, was a Persian poet and the author of Shahnameh, the national epic of Greater Iran.",
      "themes": "Heroism, Patriotism, Tragedy, Honor",
      "avatar": "🛡",
      "famous_poem": "چو رستم به نبرد با سهراب آمد"
    },
    {
      "id": "attar",
      "name": "عطار (Attar)",
      "bio": "Farid al-Din Attar of Nishapur was a Persian poet, theoretician of Sufism, and hagiographer from Nishapur whose works influenced later poets like Rumi.",
      "themes": "Sufi Journey, Self-Realization, The Seven Valleys",
      "avatar": "🦅",
      "famous_poem": "جان در راه او به سخن آمد"
    },
    {
      "id": "nizami",
